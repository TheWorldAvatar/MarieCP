# Production demo overrides for zaha-01 / www.theworldavatar.io
# Copy to configs/demo_local.env on the server (no secrets here).

MINI_MARIE_DATA_DIR=/home/xz378/mini_marie_data/data

# After online probe, replay from warmed SQLite caches
DEMO_AUTO_OFFLINE=true
DEMO_FORCE_REFRESH=false

# Classic static Marie UI — no Next.js on the server
MARIE_FRONTEND_PROXY=0
# Optional explicit redirect target (defaults to same-origin /demos/marie-classic/)
# MARIE_FRONTEND_URL=https://www.theworldavatar.io/demos/marie-classic

# Flask bind (nginx terminates TLS and proxies to this port)
DEMO_HOST=127.0.0.1
DEMO_PORT=8080
