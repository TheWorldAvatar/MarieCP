# Official Marie Next.js frontend (next_app_marie) — dev against MarieCP Flask API
# Copy to vendor/.../next_app_marie/.env.local (or run: python -m demos.setup_marie_frontend)

# Browser + Next SSR fetch target (must include trailing slash per upstream README)
NEXT_PUBLIC_BACKEND_ENDPOINT=http://127.0.0.1:8080/demos/marie/api/

# Same as TWA production (.env.production in upstream repo)
BASE_PATH=/demos/marie

# Set on Flask demo server when Next dev runs on another port (enables CORS)
MARIE_FRONTEND_DEV=1

# Flask redirects /demos/marie/* to this URL (official Next.js dev server)
MARIE_FRONTEND_URL=http://127.0.0.1:3000/demos/marie

# Hybrid WSL frontend + Windows API: bind Flask on all interfaces so WSL SSR can reach it
DEMO_HOST=0.0.0.0
