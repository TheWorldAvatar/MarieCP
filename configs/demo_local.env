# Local demo overrides (safe to commit — no secrets).
# Points warmed caches at D:\mini_marie_data\data (mini_marie_cache lives underneath).
MINI_MARIE_DATA_DIR=D:/mini_marie_data/data

# Default LLM for demo server (API key stays in repo-root .env)
DEMO_LLM_MODEL=gpt-4o

# Online probe → offline full-cache replay (matches core KGQA default)
DEMO_AUTO_OFFLINE=true

# Bypass SPARQL/tool result cache on each question (fresh online probe every time)
DEMO_FORCE_REFRESH=true

# Official Marie Next.js UI — proxied at /demos/marie/ on the demo server (port 8080).
# Next.js dev server runs in WSL on :3000; Flask auto-detects WSL IP when localhost fails.
MARIE_FRONTEND_PROXY=1
# MARIE_FRONTEND_UPSTREAM=http://172.30.148.210:3000
