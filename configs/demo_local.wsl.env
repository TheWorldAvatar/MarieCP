# WSL overrides — use /mnt/d/ instead of D:/ (Windows paths break SQLite under Linux)
MINI_MARIE_DATA_DIR=/mnt/d/mini_marie_data/data
MARIE_FRONTEND_URL=http://127.0.0.1:3000/demos/marie

# Bind Flask on all interfaces so Windows can reach WSL (127.0.0.1-only fails on many setups)
DEMO_HOST=0.0.0.0
