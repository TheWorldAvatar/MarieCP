# Docker demo overrides (MINI_MARIE_DATA_DIR mounted at /data in container)
MINI_MARIE_DATA_DIR=/data

DEMO_AUTO_OFFLINE=true
DEMO_FORCE_REFRESH=false

MARIE_FRONTEND_PROXY=0

DEMO_HOST=0.0.0.0
DEMO_PORT=8080

# Host publish (docker compose maps MARIECP_PORT -> container 8080)
MARIECP_PORT=3001
MARIECP_PUBLISH_HOST=0.0.0.0
