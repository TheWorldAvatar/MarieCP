{
  "id": "WF_TOP10_LOCATIONS_JOIN_KL",
  "question": "What are the tallest 10 buildings in Kaiserslautern (SQL cache join, offline)",
  "city": "kaiserslautern",
  "top_n": 10,
  "online_limit": 10,
  "steps": [
    {
      "id": "online_list_probe",
      "comment": "Online: small probe. Offline: full height pool from facet.",
      "tool": "list_buildings_with_height",
      "args": { "city": "$city" },
      "extract": { "building_pool": { "pick": "all_rows" } }
    },
    {
      "id": "offline_pool",
      "type": "local_join",
      "join": "building_pool_from_cache",
      "city": "$city",
      "output_variable": "building_pool",
      "offline_only": true
    },
    {
      "id": "rank_top",
      "type": "transform",
      "transform": "top_n_by_field",
      "input_variable": "building_pool",
      "field": "height",
      "n": "$top_n",
      "order": "desc",
      "output_field": "building",
      "output_variable": "top_building_iris",
      "also_store_rows": "top_building_rows"
    },
    {
      "id": "sql_join_locations",
      "comment": "Indexed SQL join on top-N building IRIs — no full location pool load.",
      "type": "local_join",
      "join": "top_n_with_locations_from_cache",
      "city": "$city",
      "n": "$top_n",
      "output_variable": "buildings_with_wkt",
      "offline_only": true,
      "extract": { "location_join_rows": { "pick": "all_rows" } }
    }
  ],
  "final_summary": "Top $top_n tallest buildings in $city with joined WKT."
}
