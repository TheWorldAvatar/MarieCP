    },
    {
      "id": "mq21_h2o2_reactions",
      "title": "MQ21 — mechanisms with H2O2 reactions",
      "steps": [
        {
          "tool": "traverse_mechanism_reactions",
          "args": {
            "namespace": "ontokin",
            "reaction_fragment": "H2O2"
          },
          "output_variable": "reactions"
        }
      ],
      "answer_variable": "reactions"
    },
    {
      "id": "mq22_o2_and_ar_mechanisms",
      "title": "MQ22 — mechanisms containing both O2 and Ar reactions",
      "steps": [
        {
          "tool": "traverse_mechanism_reactions",
          "args": {
            "namespace": "ontokin",
            "reaction_fragment": "O2"
          },
          "output_variable": "o2_reactions"
        },
        {
          "tool": "traverse_mechanism_reactions",
          "args": {
            "namespace": "ontokin",
            "reaction_fragment": "Ar"
          },
          "output_variable": "ar_reactions"
        },
        {
          "type": "transform",
          "transform": "intersect_keys",
          "name": "mechanisms_with_o2_and_ar",
          "left_variable": "o2_reactions",
          "right_variable": "ar_reactions",
          "key": "mechanism",
          "output_variable": "both_mechanisms",
          "offline_only": true
        }
      ],
      "answer_variable": "both_mechanisms"
    },
    {
      "id": "mq26_h2_oh_rate_constants",
      "title": "MQ26 — compare H2+OH rate constants across mechanisms",
      "steps": [
        {
          "tool": "compare_rate_constants",
          "args": {
            "namespace": "ontokin",
            "equation_fragment": "H2 + OH"
          },
          "output_variable": "rate_rows"
        }
      ],
      "answer_variable": "rate_rows"
    },
    {
      "id": "mq43_h2s_guest",
      "title": "MQ43 — zeolite materials with H2S guest formula",
      "steps": [
        {
          "tool": "filter_by_literal",
          "args": {
            "namespace": "ontozeolite",
            "class_local": "ZeoliticMaterial",
            "property_local": "hasGuestFormula",
            "value_fragment": "H2S"
          },
          "output_variable": "materials"
        }
      ],
      "answer_variable": "materials"
    },
    {
      "id": "mq34_framework_aen",
      "title": "MQ34 — zeolitic materials for framework AEN",
      "steps": [
        {
          "tool": "filter_by_literal",
          "args": {
            "namespace": "ontozeolite",
            "class_local": "ZeoliticMaterial",
            "property_local": "hasFrameworkCode",
            "value_fragment": "AEN"
          },
          "output_variable": "materials"
        }
      ],
      "answer_variable": "materials"
    },
    {
      "id": "mq41_zeolite_area_volume",
      "title": "MQ41 — zeolites filtered by accessible area and occupiable volume per cell",
      "parameters": {
        "min_accessible_area": {
          "default": 500,
          "comparator": "gt",
          "order": 0,
          "hints": ["accessible area", "area per cell"]
        },
        "max_volume_per_cell": {
          "default": 200,
          "comparator": "lt",
          "order": 1,
          "hints": ["occupiable volume", "volume per cell"]
        }
      },
      "steps": [
        {
          "tool": "list_zeolite_numeric_props",
          "args": {
            "namespace": "ontozeolite"
          },
          "output_variable": "numeric_rows"
        },
        {
          "type": "transform",
          "transform": "filter_rows",
          "name": "area_volume_filter",
          "input_variable": "numeric_rows",
          "output_variable": "filtered_materials",
          "logic": "and",
          "filters": [
            {"field": "accessible_area_per_cell", "op": "gt", "value": "$min_accessible_area"},
            {"field": "occupiable_volume_per_cell", "op": "lt", "value": "$max_volume_per_cell"}
          ],
          "offline_only": true,
          "online_preview": true
        }
      ],
      "answer_variable": "filtered_materials"
    },
    {
      "id": "mq31_zpe_species",
      "title": "MQ31 — zero-point energy for species fragment 663e4fd4",
      "steps": [
        {
