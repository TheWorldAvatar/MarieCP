{
  "workflows": [
    {
      "id": "mq01_ethylene_glycol_hbond",
      "title": "MQ1 — ethylene glycol H-bond donor/acceptor counts",
      "steps": [
        {
          "tool": "query_physprops_wide",
          "args": {
            "namespace": "ontospecies",
            "smiles": "C(CO)O"
          },
          "output_variable": "hbond_rows"
        }
      ],
      "answer_variable": "hbond_rows"
    },
    {
      "id": "mq02_amino_propanol_uses",
      "title": "MQ2 — uses of 3-amino-2-propanol",
      "tags": ["expected_empty"],
      "steps": [
        {
          "tool": "search_uses_enriched",
          "args": {
            "namespace": "ontospecies",
            "use_fragment": "3-amino-2-propanol"
          },
          "output_variable": "use_rows"
        }
      ],
      "answer_variable": "use_rows"
    },
    {
      "id": "mq03_formula_c6h8o6",
      "title": "MQ3 — species with molecular formula C6H8O6",
      "steps": [
        {
          "tool": "filter_by_literal",
          "args": {
            "namespace": "ontospecies",
            "class_local": "Species",
            "property_local": "hasMolecularFormula",
            "value_fragment": "C6H8O6",
            "match": "equals"
          },
          "output_variable": "species_rows"
        }
      ],
      "answer_variable": "species_rows"
    },
    {
      "id": "mq04_pka_inchi_c6h15n",
      "title": "MQ4 — pKa for InChI C6H15N tertiary amine",
      "steps": [
        {
          "tool": "query_pka_enriched",
          "args": {
            "namespace": "ontospecies",
            "species_fragment": "InChI=1S/C6H15N/c1-5(2)7-6(3)4/h5-7H,1-4H3"
          },
          "output_variable": "pka_rows"
        }
      ],
      "answer_variable": "pka_rows"
    },
    {
      "id": "mq05_pka_propenoic_acid",
      "title": "MQ5 — pKa values for propenoic acid",
      "steps": [
        {
          "tool": "query_pka_enriched",
          "args": {
            "namespace": "ontospecies",
            "species_fragment": "propenoic acid"
          },
          "output_variable": "pka_rows"
        }
      ],
      "answer_variable": "pka_rows"
    },
    {
      "id": "mq06_pka_butanoic_smiles",
      "title": "MQ6 — pKa for CCCC(=O)O",
      "steps": [
        {
          "tool": "query_pka_enriched",
          "args": {
            "namespace": "ontospecies",
            "species_fragment": "CCCC(=O)O"
          },
          "output_variable": "pka_rows"
        }
      ],
      "answer_variable": "pka_rows"
    },
    {
      "id": "mq07_pka_diamine_inchi",
      "title": "MQ7 — pKa for methylenediamine InChI",
      "tags": ["expected_empty"],
      "steps": [
        {
          "tool": "query_pka_enriched",
          "args": {
            "namespace": "ontospecies",
            "species_fragment": "InChI=1S/C2H6N2/c1-2(3)4/h1H3,(H3,3,4)"
          },
          "output_variable": "pka_rows"
        }
      ],
      "answer_variable": "pka_rows"
    },
    {
      "id": "mq08_acetic_temp_dependence",
      "title": "MQ8 — acetic acid pKa vs temperature",
      "tags": ["expected_empty"],
      "steps": [
        {
          "tool": "query_pka_enriched",
          "args": {
            "namespace": "ontospecies",
            "species_fragment": "acetic acid"
          },
          "output_variable": "pka_rows"
        },
        {
          "type": "transform",
          "transform": "filter_rows",
          "name": "non_empty_temperature",
          "input_variable": "pka_rows",
          "output_variable": "temp_rows",
          "logic": "and",
          "filters": [
            {"field": "temperature", "op": "ne", "value": ""}
          ],
          "offline_only": true
        }
      ],
      "answer_variable": "temp_rows"
    },
    {
      "id": "mq09_perrin2_temp",
      "title": "MQ9 — perrin2 temperature dependence of pKaH1",
      "tags": ["expected_empty"],
      "steps": [
        {
          "tool": "query_pka_enriched",
          "args": {
            "namespace": "ontospecies",
            "ref_label_fragment": "perrin2",
            "acidity_label_fragment": "pKaH1"
          },
          "output_variable": "pka_rows"
        }
      ],
      "answer_variable": "pka_rows"
    },
    {
      "id": "mq10_high_pressure_pka",
      "title": "MQ10 — species with pKa at high pressures",
      "tags": ["expected_empty"],
      "steps": [
        {
          "tool": "query_pka_enriched",
          "args": {
            "namespace": "ontospecies",
            "method_fragment": "pressure"
          },
          "output_variable": "pka_rows"
        }
      ],
      "answer_variable": "pka_rows"
    },
    {
      "id": "mq11_most_pka_species",
      "title": "MQ11 — species with most pKaH values",
      "steps": [
        {
          "tool": "query_species_profile_top",
          "args": {
            "namespace": "ontospecies",
            "limit": 10
          },
          "output_variable": "profile_rows"
        }
      ],
      "answer_variable": "profile_rows"
    },
    {
      "id": "mq12_methylamine_ionic",
      "title": "MQ12 — ionic strengths for methylamine pKa",
      "steps": [
        {
          "tool": "query_pka_enriched",
          "args": {
            "namespace": "ontospecies",
            "species_fragment": "methylamine"
          },
          "output_variable": "pka_rows"
        }
      ],
      "answer_variable": "pka_rows"
    },
    {
      "id": "mq13_multi_source_pka",
      "title": "MQ13 — compounds with pKa across multiple sources",
      "parameters": {
        "min_source_count": {
          "default": 1,
          "comparator": "gt",
          "order": 0,
          "hints": ["multiple sources", "source count"]
        }
      },
      "steps": [
        {
          "tool": "query_pka_enriched",
          "args": {
            "namespace": "ontospecies"
          },
          "output_variable": "pka_pool"
        },
        {
          "type": "transform",
          "transform": "group_aggregate",
          "name": "sources_per_species",
          "input_variable": "pka_pool",
          "output_variable": "multi_source",
          "group_by": ["species_iri", "primary_label"],
          "aggregations": [
            {"op": "count_distinct", "field": "provenance", "as": "source_count"}
          ],
          "offline_only": true
        },
        {
          "type": "transform",
          "transform": "filter_rows",
          "name": "multi_source_filter",
          "input_variable": "multi_source",
          "output_variable": "multi_source_rows",
          "logic": "and",
          "filters": [
            {"field": "source_count", "op": "gt", "value": "$min_source_count"}
          ],
          "offline_only": true,
          "online_preview": true
        }
      ],
      "answer_variable": "multi_source_rows"
    },
    {
      "id": "mq14_uncertain_reliability_pka",
      "title": "MQ14 — methods most often tagged Uncertain reliability",
      "tags": ["expected_empty"],
      "steps": [
        {
          "tool": "query_pka_enriched",
          "args": {
            "namespace": "ontospecies",
            "reliability_fragment": "uncertain"
          },
          "output_variable": "uncertain_pool"
        },
        {
          "type": "transform",
          "transform": "group_aggregate",
          "name": "uncertain_by_method",
          "input_variable": "uncertain_pool",
          "output_variable": "method_counts",
          "group_by": ["method"],
          "aggregations": [
            {"op": "count", "as": "count"}
          ],
          "order_by": {"field": "count", "order": "desc"},
          "offline_only": true
        }
      ],
      "answer_variable": "method_counts"
    },
    {
      "id": "mq15_pka_and_pkb",
      "title": "MQ15 — compounds with both pKa and pKb measurements",
      "tags": ["expected_empty"],
      "steps": [
        {
          "tool": "query_pka_enriched",
          "args": {
            "namespace": "ontospecies"
          },
          "output_variable": "pka_pool"
        },
        {
          "type": "transform",
          "transform": "group_aggregate",
          "name": "acidity_labels_per_species",
          "input_variable": "pka_pool",
          "output_variable": "label_counts",
          "group_by": ["species_iri", "primary_label", "acidity_label"],
          "aggregations": [
            {"op": "count", "as": "count"}
          ],
          "offline_only": true
        },
        {
          "type": "transform",
          "transform": "group_aggregate",
          "name": "both_pka_pkb",
          "input_variable": "label_counts",
          "output_variable": "both_rows",
          "group_by": ["species_iri", "primary_label"],
          "aggregations": [
            {"op": "count_distinct", "field": "acidity_label", "as": "label_kinds"}
          ],
          "offline_only": true
        },
        {
          "type": "transform",
          "transform": "filter_rows",
          "name": "at_least_two_labels",
          "input_variable": "both_rows",
          "output_variable": "pka_pkb_rows",
          "logic": "and",
          "filters": [
            {"field": "label_kinds", "op": "gte", "value": 2}
          ],
          "offline_only": true
        }
      ],
      "answer_variable": "pka_pkb_rows"
    },
    {
      "id": "mq16_uncertain_pka",
      "title": "MQ16 — pK measurements tagged Uncertain",
      "tags": ["expected_empty"],
      "steps": [
        {
          "tool": "query_pka_enriched",
          "args": {
            "namespace": "ontospecies",
            "reliability_fragment": "uncertain"
          },
          "output_variable": "pka_rows"
        }
      ],
      "answer_variable": "pka_rows"
    },
    {
      "id": "mq17_methylamine_provenance",
