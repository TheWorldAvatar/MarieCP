{
  "id": "MOF_COMPETENCY_SUITE",
  "description": "Human-made competency questions (CompetencyQs.md) as cached atomic workflows",
  "online_limit": 10,
  "offline_cap": 500000,
  "workflows": [
    {
      "id": "CQ01_PLD_UIO66",
      "question": "What are the average and variance of the pore limiting diameter for UiO-66?",
      "steps": [{ "tool": "get_pld_stats_by_mof_name", "args": { "mof_name": "UiO-66" } }]
    },
    {
      "id": "CQ02_ZN_SOURCES",
      "question": "Which Zn-containing MOFs are available, grouped by source database?",
      "steps": [
        {
          "tool": "get_mofs_by_metal",
          "args": { "metal": "Zn", "list_sources": true }
        }
      ]
    },
    {
      "id": "CQ02B_ZN_CORE_FILTER",
      "question": "Which Zn-containing MOFs come from CoRE databases, and how do their source statistics compare with all Zn MOFs?",
      "metal": "Zn",
      "db_substring": "core",
      "steps": [
        {
          "id": "list_zn_mofs",
          "tool": "get_mofs_by_metal",
          "args": { "metal": "$metal" },
          "extract": { "zn_pool": { "pick": "all_rows" } }
        },
        {
          "id": "filter_core",
          "type": "transform",
          "transform": "filter_rows",
          "name": "core_database_filter",
          "input_variable": "zn_pool",
          "output_variable": "core_zn_rows",
          "filters": [
            { "field": "sourcedb", "op": "icontains", "value": "$db_substring" }
          ]
        },
        {
          "id": "zn_source_stats",
          "tool": "get_mofs_by_metal",
          "args": { "metal": "$metal", "list_sources": true },
          "extract": { "zn_source_stats": { "pick": "all_rows" } }
        }
      ],
      "final_summary": "CoRE-filtered Zn MOF rows=$core_zn_rows (pool size after filter); all Zn source stats=$zn_source_stats"
    },
    {
      "id": "CQ02C_ZN_CORE_GROUP_RESIDUAL",
      "question": "Among Zn-containing MOFs from CoRE databases, how many come from each source database, and how does that compare with the total MOF count?",
      "metal": "Zn",
      "db_substring": "core",
      "steps": [
        {
          "tool": "get_mofs_by_metal",
          "args": { "metal": "$metal" },
          "extract": { "zn_pool": { "pick": "all_rows" } }
        },
        {
          "type": "transform",
          "transform": "filter_rows",
          "input_variable": "zn_pool",
          "output_variable": "core_zn_rows",
          "filters": [
            { "field": "sourcedb", "op": "icontains", "value": "$db_substring" }
          ]
        },
        {
          "type": "transform",
          "transform": "group_aggregate",
          "name": "count_by_source",
          "input_variable": "core_zn_rows",
          "output_variable": "core_zn_by_source",
          "group_by": ["sourcedb"],
          "aggregations": [
            { "op": "count_distinct", "field": "mof", "as": "count" }
          ],
          "order_by": { "field": "count", "order": "desc" }
        },
        {
          "type": "sparql",
          "name": "total_mof_count",
          "offline_only": true,
          "query": "PREFIX mofs: <https://www.theworldavatar.com/kg/ontomofs_vkg/>\nSELECT (COUNT(DISTINCT ?mof) AS ?count) WHERE { ?mof a mofs:MetalOrganicFramework . }",
          "extract": { "total_mof_count": { "pick": "row_field", "field": "count", "index": 0 } }
        }
      ],
      "final_summary": "CoRE Zn groups=$core_zn_by_source; corpus MOF count=$total_mof_count"
    },
    {
      "id": "CQ03_CU_EXPERIMENTAL",
      "question": "How many experimental Cu-containing MOFs are recorded?",
      "steps": [
        {
          "tool": "get_mofs_by_metal",
          "args": { "metal": "Cu", "count_only": true, "experimental_only": true }
        }
      ]
    },
    {
      "id": "CQ04_SYNTHESIS_UIO66",
      "question": "What synthesis routes are recorded for UiO-66?",
      "steps": [
        { "tool": "get_synthesis_by_mof_name", "args": { "mof_name": "uio-66" } }
      ]
    },
    {
      "id": "CQ05_IDENTITY_DUT67",
      "question": "What is the identity of DUT-67, including its space group and source databases?",
      "steps": [{ "tool": "get_mof_identity_by_name", "args": { "mof_name": "DUT-67" } }]
    },
    {
      "id": "CQ06_TOPOLOGY_ZIF8",
      "question": "What topology is recorded for ZIF-8?",
      "steps": [{ "tool": "get_mof_identity_by_name", "args": { "mof_name": "ZIF-8" } }]
    },
    {
      "id": "CQ07_SAME_TOPO_ZIF8",
      "question": "Which MOFs have the same topology as ZIF-8?",
      "steps": [
        { "tool": "get_mof_identity_by_name", "args": { "mof_name": "ZIF-8" } },
        {
          "tool": "get_mofs_with_same_topology_as",
          "args": { "reference_name": "ZIF-8" }
        },
        {
          "tool": "get_mofs_with_same_topology_as",
          "args": { "reference_name": "ZIF-8", "count_only": true },
          "extract": { "sparql_count": { "pick": "row_field", "field": "count", "index": 0 } }
        },
        {
          "type": "local_join",
          "join": "topology_from_identity",
          "reference_name": "ZIF-8",
          "output_variable": "topology",
          "offline_only": true
        },
        {
          "type": "local_join",
          "join": "same_topology_count_local",
          "topology": "$topology",
          "exclude_reference": "ZIF-8",
          "offline_only": true,
          "extract": { "local_count": { "pick": "row_field", "field": "count", "index": 0 } }
        }
      ],
      "final_summary": "topology=$topology; corpus_count=$sparql_count; facet_sample_count=$local_count"
    },
    {
      "id": "CQ08_LINKER_HKUST",
      "question": "What linker SMILES are recorded for HKUST-1?",
      "steps": [{ "tool": "get_linkers_by_mof_name", "args": { "mof_name": "HKUST-1" } }]
    },
    {
      "id": "CQ09_HYPO_MIL53",
      "question": "How many hypothetical MOFs have the same topology as MIL-53?",
      "steps": [
        {
          "tool": "count_hypothetical_same_topology_as",
          "args": { "reference_name": "MIL-53" }
        }
      ]
    },
    {
      "id": "CQ10_EXP_PCU",
      "question": "How many experimental MOFs have pcu topology?",
      "steps": [{ "tool": "count_experimental_by_topology", "args": { "topology": "pcu" } }]
    },
    {
      "id": "CQ11_PORE_HKUST",
      "question": "What pore metrics are recorded for HKUST-1?",
      "steps": [{ "tool": "get_pore_metrics_by_mof_name", "args": { "mof_name": "HKUST-1" } }]
    },
    {
      "id": "CQ12_GSA_2500",
      "question": "Which MOFs have a gravimetric surface area of at least 2500?",
      "steps": [{ "tool": "get_mofs_by_gsa_min", "args": { "min_gsa": 2500 } }]
    },
    {
      "id": "CQ13_DOI_MIL101",
      "question": "Which publications are associated with MIL-101?",
      "steps": [{ "tool": "get_publications_by_mof_name", "args": { "mof_name": "mil-101" } }]
    },
    {
      "id": "CQ14_ASA_MIL53",
      "question": "What accessible surface area is recorded for MIL-53?",
      "steps": [{ "tool": "get_asa_by_mof_name", "args": { "mof_name": "mil-53" } }]
    },
    {
      "id": "CQ15_DENSITY_DUT67",
      "question": "What density and pore statistics are recorded for DUT-67?",
      "steps": [{ "tool": "get_pore_metrics_by_mof_name", "args": { "mof_name": "DUT-67" } }]
    },
    {
      "id": "CQ16_LCD_LT20",
      "question": "Which MOFs have a largest cavity diameter below 20 Å?",
      "steps": [{ "tool": "get_mofs_by_lcd_max", "args": { "max_lcd_angstrom": 20 } }]
    },
    {
      "id": "CQ17_SOLVENTS",
      "question": "What are the most common synthesis solvents after excluding DMF, DMA, and HF?",
      "steps": [{ "tool": "get_top_synthesis_solvents", "args": {} }]
    },
    {
      "id": "CQ_D1_ZR_COOH",
      "question": "Which Zr-containing MOFs have carboxylate linkers?",
      "steps": [{ "tool": "get_mofs_by_metal_and_linker", "args": {} }]
    },
    {
      "id": "CQ_D2_PCU_ALL",
      "question": "How is pcu topology distributed across MOF source databases?",
      "steps": [{ "tool": "get_mofs_by_topology_all_sources", "args": { "topology": "pcu" } }]
    },
    {
      "id": "CQ_D3_ZIF8_REFCODES_SYNTH",
      "question": "Which ZIF-8 refcodes have matching synthesis records?",
      "steps": [
        {
          "tool": "get_refcodes_by_mof_name",
          "args": { "mof_name": "ZIF-8" },
          "extract": {
            "refcodes": { "pick": "column", "field": "refcode" }
          }
        },
        {
          "tool": "get_synthesis_by_mof_name",
          "args": { "mof_name": "ZIF-8" },
          "extract": { "synthesis_rows": { "pick": "all_rows" } }
        },
        {
          "type": "transform",
          "transform": "join_rows",
          "name": "synthesis_by_refcodes",
          "left_variable": "synthesis_rows",
          "right_variable": "refcodes",
          "left_key": "refcode",
          "right_is_list": true,
          "how": "inner",
          "output_variable": "filtered_synthesis",
          "offline_only": true,
          "extract": { "filtered_synthesis_rows": { "pick": "all_rows" } }
        }
      ],
      "final_summary": "Refcodes=$refcodes; filtered synthesis rows=$filtered_synthesis_rows"
    },
    {
      "id": "CQ_D4_AQUEOUS",
      "question": "Which MOFs have aqueous low-temperature synthesis routes?",
      "steps": [{ "tool": "get_aqueous_low_temp_syntheses", "args": {} }]
    },
    {
      "id": "CQ_D5_WATER_STABLE",
      "question": "Which MOFs are reported as water-stable?",
      "steps": [{ "tool": "get_water_stable_mofs", "args": {} }]
    },
    {
      "id": "CQ_D6_THERMAL",
      "question": "Which MOFs are reported as thermally stable?",
      "steps": [{ "tool": "get_thermal_stable_mofs", "args": {} }]
    },
    {
      "id": "CQ_D7_BINARY_UPTAKE",
      "question": "Which MOFs have high binary gas uptake?",
      "steps": [{ "tool": "get_high_binary_gas_uptake_mofs", "args": {} }]
    },
    {
      "id": "CQ_MORE03_NIST_ADSORPTION_CHEM",
      "question": "Which NIST adsorption MOFs can be joined to CoRE chemistry records, with Tobassco functional groups when available?",
      "steps": [
        {
          "id": "warm_nist",
          "tool": "get_nist_exp_adsorption_rows",
          "args": {},
          "extract": { "nist_pool": { "pick": "all_rows" } }
        },
        {
          "id": "warm_core",
          "tool": "get_core_name_chemistry_rows",
          "args": {},
          "extract": { "core_pool": { "pick": "all_rows" } }
        },
        {
          "id": "warm_tob",
          "tool": "get_tobassco_func_groups_by_mofid",
          "args": {},
          "extract": { "tob_pool": { "pick": "all_rows" } }
        },
        {
          "type": "transform",
          "transform": "multi_join_rows",
          "name": "nist_core_tob_join",
          "left_variable": "nist_pool",
          "output_variable": "enriched_rows",
          "offline_only": true,
          "joins": [
            {
              "right_variable": "core_pool",
              "left_key": "name_lc",
              "right_key": "name_lc",
              "how": "inner",
              "right_prefix": "core_"
            },
            {
              "right_variable": "tob_pool",
              "left_key": "core_mofid",
              "right_key": "mofid",
              "how": "left",
              "right_prefix": "tob_"
            }
          ],
          "extract": { "result_rows": { "pick": "all_rows" } }
        }
      ],
      "final_summary": "NIST+CoRE+Tobassco enriched rows=$result_rows (count in workflow result)"
    }
  ]
}
