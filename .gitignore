# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
.env

# IDE / notebooks
.idea/
.vscode/
*.swp
.ipynb_checkpoints/

# Runtime data (SQLite caches, logs, exports)
data/*
!data/.gitkeep
raw_data/*
!raw_data/.gitkeep
evaluation/data/merged_tll/*
!evaluation/data/merged_tll/.gitkeep

# Generated workflow / probe outputs
**/competency_runs/*.json
**/competency_runs/*.md
!**/competency_runs/.gitignore
**/workflow_runs/*.json
**/workflow_runs/*.ndjson
!**/workflow_runs/.gitignore
**/headless_runs/*.json
**/headless_runs/*.md
!**/headless_runs/.gitignore
**/maps/*.html
!**/maps/.gitignore
**/probe_results*.json
**/warm_option_catalog.discovered.json
**/competency_eval_results.*
**/competency_eval_run.log

# Demo audit / analysis outputs
demos/audit_runs/
data/demo_analysis.json

# Test / tooling caches
.pytest_cache/

# OS
.DS_Store
Thumbs.db

# Mirrored TWA demo static assets (download with python -m demos.mirror)
demos/static/

# Official Marie Next.js frontend (clone with python -m demos.setup_marie_frontend)
vendor/TheWorldAvatar/
vendor/**/node_modules/
.venv-wsl/

# Archives (use extracted source in repo instead)
*.rar
*.zip
